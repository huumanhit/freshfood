# ============================================================
# APPLICATION
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="FreshFood"

# ============================================================
# DATABASE (MySQL via Prisma)
# ============================================================
DATABASE_URL="mysql://root:password@localhost:3306/freshfood"

# ============================================================
# NEXTAUTH / AUTH.JS
# ============================================================
AUTH_SECRET="your-auth-secret-at-least-32-chars"
AUTH_URL=http://localhost:3000

# OAuth Providers (optional)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# ============================================================
# CLOUDINARY (Image Upload)
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ============================================================
# EMAIL (NodeMailer / Resend)
# ============================================================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="FreshFood <noreply@freshfood.vn>"

# ============================================================
# PAYMENT (VNPay / Stripe)
# ============================================================
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/checkout/vnpay-return

# Stripe (fallback / international)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# REDIS (session / cache — optional)
# ============================================================
REDIS_URL=redis://localhost:6379
