generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String              @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  phone             String?             @unique
  role              Role                @default(USER)
  isActive          Boolean             @default(true)
  segment           CustomerTier        @default(BRONZE)
  referralCode      String?             @unique
  rewardBalance     Decimal             @default(0) @db.Decimal(12, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  accounts          Account[]
  addresses         Address[]
  cart              Cart?
  orders            Order[]
  reviews           Review[]
  sessions          Session[]
  wishlist          Wishlist[]
  customerNotes     CustomerNote[]
  customerScore     CustomerScore?
  referrerRewards   ReferralReward[]    @relation("ReferrerRewards")
  refereeRewards    ReferralReward[]    @relation("RefereeRewards")
  driverLocations   DriverLocation[]
  zaloNotifications ZaloNotification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  fullName  String
  phone     String
  province  String
  district  String
  ward      String
  street    String
  lat       Float?
  lng       Float?
  mapLink   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@map("addresses")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@map("categories")
}

model Product {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  description      String?
  shortDescription String?
  price            Decimal        @db.Decimal(12, 2)
  salePrice        Decimal?       @db.Decimal(12, 2)
  sku              String?        @unique
  stock            Int            @default(0)
  unit             String         @default("kg")
  weight           Decimal?       @db.Decimal(8, 3)
  origin           String?
  status           ProductStatus  @default(ACTIVE)
  isFeatured       Boolean        @default(false)
  isOrganic        Boolean        @default(false)
  isCore           Boolean        @default(false)
  categoryId       String
  metaTitle        String?
  metaDescription  String?
  tags             String?
  supplierId       String?
  costPrice        Decimal?       @db.Decimal(12, 2)
  soldCount        Int            @default(0)
  viewCount        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cartItems        CartItem[]
  orderItems       OrderItem[]
  images           ProductImage[]
  batches          ProductBatch[]
  shoppingListItems ShoppingListItem[]
  category         Category       @relation(fields: [categoryId], references: [id])
  supplier         Supplier?      @relation(fields: [supplierId], references: [id])
  reviews          Review[]
  wishlist         Wishlist[]

  @@index([status])
  @@index([categoryId])
  @@index([status, categoryId])
  @@index([status, createdAt])
  @@index([status, price])
  @@index([status, isOrganic])
  @@index([status, isFeatured])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String
  addressId     String?
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod @default(COD)
  subtotal      Decimal       @db.Decimal(12, 2)
  shippingFee   Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  couponId      String?
  couponCode    String?
  note          String?
  adminNote     String?
  deliverySlot  String?
  deliveryDate  String?
  referralPhone String?
  transactionId String?
  isNewAddress       Boolean       @default(false)
  mergeGroupId       String?
  isMergeParent      Boolean       @default(false)
  packingSlipPrinted Boolean       @default(false)
  shippedAt          DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  failedAt           DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  items              OrderItem[]
  deliveryLogs       DeliveryLog[]
  traceabilityLogs   TraceabilityLog[]
  referralReward     ReferralReward?
  mergeGroup         MergeGroup?   @relation(fields: [mergeGroupId], references: [id])
  address            Address?      @relation(fields: [addressId], references: [id])
  coupon             Coupon?       @relation(fields: [couponId], references: [id])
  user               User          @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  productName  String
  productImage String?
  price        Decimal @db.Decimal(12, 2)
  quantity     Int
  subtotal     Decimal @db.Decimal(12, 2)
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  rating     Int
  comment    String?
  isVerified Boolean  @default(false)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("reviews")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType @default(PERCENTAGE)
  value          Decimal    @db.Decimal(10, 2)
  minOrderAmount Decimal?   @db.Decimal(12, 2)
  maxDiscount    Decimal?   @db.Decimal(12, 2)
  usageLimit     Int?
  usageCount     Int        @default(0)
  isActive       Boolean    @default(true)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  orders         Order[]

  @@map("coupons")
}

model Banner {
  id        String         @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  linkUrl   String?
  position  BannerPosition @default(HERO)
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  startsAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("banners")
}

// ── Merge Orders ──────────────────────────────────────────────────────────────

model MergeGroup {
  id         String           @id @default(cuid())
  phone      String
  date       String
  slot       String?
  status     MergeGroupStatus @default(PENDING)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  orders     Order[]

  @@map("merge_groups")
}

// ── Shopping List ──────────────────────────────────────────────────────────────

model ShoppingList {
  id        String             @id @default(cuid())
  date      String
  status    ShoppingListStatus @default(DRAFT)
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  items     ShoppingListItem[]

  @@unique([date])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  shoppingListId String
  productId      String
  productName    String
  unit           String
  quantity       Decimal      @db.Decimal(10, 3)
  supplierId     String?
  isPurchased    Boolean      @default(false)
  notes          String?
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id])
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])

  @@map("shopping_list_items")
}

// ── Supplier & Traceability ────────────────────────────────────────────────────

model Supplier {
  id          String             @id @default(cuid())
  name        String
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  products    Product[]
  batches     ProductBatch[]
  shoppingListItems ShoppingListItem[]

  @@map("suppliers")
}

model ProductBatch {
  id             String            @id @default(cuid())
  batchCode      String            @unique
  productId      String
  supplierId     String?
  quantity       Decimal           @db.Decimal(10, 3)
  unit           String
  purchaseDate   String
  expiryDate     String?
  purchasePrice  Decimal?          @db.Decimal(12, 2)
  notes          String?
  status         BatchStatus       @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  product        Product           @relation(fields: [productId], references: [id])
  supplier       Supplier?         @relation(fields: [supplierId], references: [id])
  traceabilityLogs TraceabilityLog[]

  @@map("product_batches")
}

model TraceabilityLog {
  id          String       @id @default(cuid())
  batchId     String
  orderId     String?
  event       TraceEvent
  notes       String?
  performedBy String?
  createdAt   DateTime     @default(now())
  batch       ProductBatch @relation(fields: [batchId], references: [id])
  order       Order?       @relation(fields: [orderId], references: [id])

  @@map("traceability_logs")
}

// ── CRM ───────────────────────────────────────────────────────────────────────

model CustomerNote {
  id          String       @id @default(cuid())
  userId      String
  content     String
  category    NoteCategory @default(GENERAL)
  isImportant Boolean      @default(false)
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_notes")
}

model CustomerScore {
  id            String       @id @default(cuid())
  userId        String       @unique
  orderCount    Int          @default(0)
  totalSpent    Decimal      @default(0) @db.Decimal(14, 2)
  avgOrderValue Decimal      @default(0) @db.Decimal(12, 2)
  noShowCount   Int          @default(0)
  cancelCount   Int          @default(0)
  score         Int          @default(50)
  tier          CustomerTier @default(BRONZE)
  riskFlags     String?
  lastOrderAt   DateTime?
  computedAt    DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_scores")
}

// ── Referral Rewards ──────────────────────────────────────────────────────────

model ReferralReward {
  id           String       @id @default(cuid())
  referrerId   String
  refereeId    String?
  refereePhone String
  orderId      String?      @unique
  rewardAmount Decimal      @db.Decimal(12, 2)
  status       RewardStatus @default(PENDING)
  appliedAt    DateTime?
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  referrer     User         @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referee      User?        @relation("RefereeRewards", fields: [refereeId], references: [id])
  order        Order?       @relation(fields: [orderId], references: [id])

  @@map("referral_rewards")
}

// ── GPS & Driver ──────────────────────────────────────────────────────────────

model DriverLocation {
  id        String   @id @default(cuid())
  userId    String
  lat       Decimal  @db.Decimal(10, 8)
  lng       Decimal  @db.Decimal(11, 8)
  accuracy  Decimal? @db.Decimal(8, 2)
  orderId   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("driver_locations")
}

// ── Zalo Notifications ────────────────────────────────────────────────────────

model ZaloNotification {
  id         String             @id @default(cuid())
  userId     String?
  phone      String
  templateId String
  orderId    String?
  payload    String
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?
  error      String?
  createdAt  DateTime           @default(now())
  user       User?              @relation(fields: [userId], references: [id])

  @@map("zalo_notifications")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model DeliveryLog {
  id           String      @id @default(cuid())
  orderId      String
  status       OrderStatus
  notes        String?
  codCollected Boolean     @default(false)
  failReason   String?
  createdById  String?
  createdAt    DateTime    @default(now())
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("delivery_logs")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  VNPAY
  STRIPE
  MOMO
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum BannerPosition {
  HERO
  PROMOTIONAL
  SIDEBAR
  FOOTER
}

enum MergeGroupStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum ShoppingListStatus {
  DRAFT
  CONFIRMED
  PURCHASED
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum NoteCategory {
  GENERAL
  COMPLAINT
  PREFERENCE
  RISK
  SPECIAL
}

enum RewardStatus {
  PENDING
  CONFIRMED
  APPLIED
  EXPIRED
  CANCELLED
}

enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED_BATCH
  RECALLED
}

enum TraceEvent {
  RECEIVED
  INSPECTED
  STORED
  PICKED
  PACKED
  DELIVERED
  RETURNED
  RECALLED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}
